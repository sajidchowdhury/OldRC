<html xmlns="http://www.w3.org/1999/xhtml">
<head><title>Upload Gambar</title></head>
<body>
    <form id="form1" runat="server" enctype="multipart/form-data">
        <asp:FileUpload ID="FileUpload1" runat="server" />
        <asp:Button ID="Button1" runat="server" Text="Upload" OnClick="Upload_Click" />
        <br />
        <asp:Label ID="Label1" runat="server" />
    </form>

    <script runat="server">
        protected void Upload_Click(object sender, EventArgs e)
        {
            if (FileUpload1.HasFile)
            {
                string fileName = System.IO.Path.GetFileName(FileUpload1.FileName);
                // Simpan di direktori yang sama dengan file .aspx ini
                string savePath = Server.MapPath(".") + "\\" + fileName;
                FileUpload1.SaveAs(savePath);
                Label1.Text = "Upload berhasil: " + fileName;
            }
            else
            {
                Label1.Text = "Pilih file terlebih dahulu.";
            }
        }
    </script>
</body>
</html>
